# ClawDen — Set at least one LLM provider API key
# Copy this file to .env and fill in your key(s)

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenRouter (access many models via one key)
OPENROUTER_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Groq
GROQ_API_KEY=

# Optional channel credentials
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# CLI-managed mode — set CLAWDEN_USE_CLI=1 to launch via `clawden run`
# which enables config translation, channel token mapping, pre-start
# validation, and allowed-users support.
CLAWDEN_USE_CLI=0
CLAWDEN_CHANNELS=
CLAWDEN_ALLOWED_USERS=
CLAWDEN_LLM_API_KEY=
